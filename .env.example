# Copy to .env and fill in. .env is gitignored.

# --- Strong (private API) -------------------------------------------------
# Strong API base URL. Not shipped here — discover it yourself by intercepting the
# Strong app once: see docs/ios-capture.md. TRAILING SLASH required.
STRONG_BACKEND=https://REPLACE-ME/
STRONG_USER=you@example.com
STRONG_PASS=your-strong-password
# x-client-build header value seen during capture (reference tool used 600013)
STRONG_CLIENT_BUILD=600013
# Unit Strong sends weights in — confirm at capture step 7. "kg" or "lb".
STRONG_WEIGHT_UNIT=kg

# --- Garmin Connect -------------------------------------------------------
GARMIN_USER=you@example.com
GARMIN_PASS=your-garmin-password
GARMIN_TOKEN_DIR=~/.garminconnect

# --- Behaviour ------------------------------------------------------------
# Max seconds between a Strong workout start and a watch activity start to pair them.
MATCH_WINDOW_S=5400
# How many days back to scan each run.
LOOKBACK_DAYS=10
# Set to 1 to fetch + match + build FITs but NOT upload/delete on Garmin.
DRY_RUN=1
